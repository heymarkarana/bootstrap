#!/usr/bin/env bash

##
##  dotFiles bootstrap script (cleaned & platform unified)
##

# Determine the original user's home directory when using sudo
if [[ -n "$SUDO_USER" ]]; then
  ORIGINAL_USER_HOME=$(eval echo "~$SUDO_USER")
else
  ORIGINAL_USER_HOME="${HOME}"
fi

#######################################################
##               Project Settings                   ##
#######################################################
DF_PROJECT_NAME="dotFiles"
DF_INSTALL_FOLDER_NAME=".${DF_PROJECT_NAME}"

BIN_NAME=$(basename "$0")
COMMAND=$1
BRANCH=$2

# Repository will be configured interactively or via environment variable
SELECTED_REPO="${DOTFILES_REPO:-}"
TARGET="${ORIGINAL_USER_HOME}/${DF_INSTALL_FOLDER_NAME}"

# Detect OS platform and return one of: macOS, ubuntu
detect_platform() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "macOS"
  elif [[ -f "/etc/lsb-release" ]] && grep -q "Ubuntu" "/etc/lsb-release"; then
    echo "ubuntu"
  else
    echo "Error: Unsupported platform. Only macOS and Ubuntu are supported." >&2
    exit 1
  fi
}

# Get current working directory as bootstrap home
set_bootstrap_home() {
  [[ -z "$DF_BOOTSTRAP_HOME" ]] && DF_BOOTSTRAP_HOME="$(pwd)"
  echo "${DF_BOOTSTRAP_HOME}"
}

DF_PLATFORM=$(detect_platform)
DF_BOOTSTRAP_HOME=$(set_bootstrap_home)

# Interactive repository configuration
configure_repository() {
  # Return if already configured via environment
  if [[ -n "$SELECTED_REPO" ]]; then
    echo "Using repository from environment: $SELECTED_REPO"
    return 0
  fi

  # Check for config file
  local config_file="${HOME}/.bootstrap.config"
  if [[ -f "$config_file" ]]; then
    source "$config_file"
    if [[ -n "$DOTFILES_REPO" ]]; then
      SELECTED_REPO="$DOTFILES_REPO"
      echo "Using repository from config: $SELECTED_REPO"
      return 0
    fi
  fi

  # Interactive prompt
  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         dotFiles Repository Configuration         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""
  echo "Enter your dotFiles repository URL:"
  echo ""
  echo "HTTPS (recommended for initial setup - no SSH keys required):"
  echo "  • https://github.com/username/dotFiles.git"
  echo "  • https://gitlab.com/username/dotFiles.git"
  echo "  • https://git.example.com/username/dotFiles.git"
  echo ""
  echo "SSH (requires SSH keys already configured):"
  echo "  • ssh://git@github.com/username/dotFiles.git"
  echo "  • ssh://git@gitlab.com/username/dotFiles.git"
  echo "  • git@github.com:username/dotFiles.git (traditional format also supported)"
  echo ""
  echo "Note: You can use either HTTPS or SSH based on your preference."
  echo ""

  read -p "Repository URL: " repo_url

  if [[ -z "$repo_url" ]]; then
    echo "Error: Repository URL is required"
    return 1
  fi

  SELECTED_REPO="$repo_url"

  # Offer to save configuration
  echo ""
  read -p "Save this configuration to ~/.bootstrap.config? (Y/n): " save_config

  if [[ ! "$save_config" =~ ^[nN]$ ]]; then
    cat > "$config_file" <<EOF
# Bootstrap Configuration
# This file is git-ignored and safe for local use
DOTFILES_REPO="$repo_url"
EOF
    chmod 600 "$config_file"
    echo "✓ Configuration saved to ~/.bootstrap.config"
  fi

  echo ""
}

show_help() {
  echo
  echo "Usage: ${BIN_NAME} <command> [branch|tag]"
  echo
  echo "Commands:"
  echo "   install                     Set up .dotFiles from scratch. Installs ZSH and Homebrew if required."
  echo "   install [branch|tag]        Specify a branch or tag to install. Defaults to 'main'."
  echo "   refresh                     Refresh the existing .dotFiles repository."
  echo "   refresh <branch|tag>        Refresh and pull a specific branch or tag."
  echo "   refresh --hard <branch|tag> Hard reset to a specific branch or tag. Deletes and reclones the repo."
  echo "   1password-reauth            Re-authenticate to 1Password when session expires."
  echo
  echo "Configuration:"
  echo "   Set DOTFILES_REPO environment variable:"
  echo "     export DOTFILES_REPO='https://github.com/username/dotFiles.git'      # HTTPS (recommended)"
  echo "     export DOTFILES_REPO='ssh://git@github.com/username/dotFiles.git'    # SSH (requires keys)"
  echo "     export DOTFILES_REPO='git@github.com:username/dotFiles.git'          # SSH traditional format"
  echo
  echo "   Or create ~/.bootstrap.config with:"
  echo "     DOTFILES_REPO='https://github.com/username/dotFiles.git'"
  echo
  echo "   Or use interactive prompts during installation."
  echo
  echo "   Note: Both HTTPS and SSH formats are supported. Use your preference."
  echo
}

# Usage: convert_git_remote_to_ssh /path/to/repo git@yourdomain:username/repo.git

convert_git_remote_to_ssh() {
  local repo_path="$1"
  local remote_url="$2"

  if [[ ! -d "$repo_path/.git" ]]; then
    echo "[✗] Not a Git repository: $repo_path"
    return 1
  fi

  # Derive SSH URL from provided HTTP(S) URL if given
  if [[ -n "$remote_url" ]]; then
    if [[ "$remote_url" =~ ^https?:// ]]; then
      # Convert http(s)://domain.com/user/repo to ssh://git@domain.com/user/repo
      remote_url=$(echo "$remote_url" | sed -E 's|^https?://|ssh://git@|')
    fi
  else
    remote_url=$(git -C "$repo_path" remote get-url origin)
    if [[ "$remote_url" =~ ^https?:// ]]; then
      # Convert http(s)://domain.com/user/repo to ssh://git@domain.com/user/repo
      remote_url=$(echo "$remote_url" | sed -E 's|^https?://|ssh://git@|')
    else
      echo "[i] Remote is already using SSH: $remote_url"
      return 0
    fi
  fi

  echo "[→] Setting remote 'origin' to: $remote_url"
  git -C "$repo_path" remote set-url origin "$remote_url"
}

# Clone git repository as user, then move to /opt with sudo
# This solves the SSH authentication issue with sudo git clone
#
# Usage: clone_repo_as_user_to_opt <repo_url> <destination_path>
clone_repo_as_user_to_opt() {
  local repo_url="$1"
  local final_dest="$2"
  local temp_clone_dir="${HOME}/.bootstrap_temp_clone_$(basename "${final_dest}")"

  # Validate inputs
  if [[ -z "$repo_url" || -z "$final_dest" ]]; then
    echo "✗ ERROR: Invalid parameters to clone_repo_as_user_to_opt"
    return 1
  fi

  echo "→ Cloning repository as user (avoids sudo SSH issues)"
  echo "  Repository: ${repo_url}"
  echo "  Temporary location: ${temp_clone_dir}"
  echo ""

  # Clean up any previous temp directory
  rm -rf "${temp_clone_dir}" 2>/dev/null

  # Clone as the regular user (has SSH access)
  if git clone "${repo_url}" "${temp_clone_dir}"; then
    echo "✓ Repository cloned successfully"
  else
    echo ""
    echo "✗ ERROR: Failed to clone repository"
    rm -rf "${temp_clone_dir}" 2>/dev/null
    return 1
  fi

  # Ensure parent directory exists
  local parent_dir=$(dirname "${final_dest}")
  if [[ ! -d "${parent_dir}" ]]; then
    echo "  Creating parent directory: ${parent_dir}"
    sudo mkdir -p "${parent_dir}" || {
      echo "✗ ERROR: Cannot create parent directory"
      rm -rf "${temp_clone_dir}"
      return 1
    }
  fi

  # Move to final destination with sudo
  echo "  Moving to final location: ${final_dest}"
  if sudo mv "${temp_clone_dir}" "${final_dest}"; then
    echo "✓ Repository moved to ${final_dest}"
  else
    echo "✗ ERROR: Failed to move repository"
    rm -rf "${temp_clone_dir}"
    return 1
  fi

  return 0
}

# Update git repository as user, handling ownership issues
# This solves the SSH authentication issue with sudo git pull
#
# Usage: update_repo_as_user <repo_path>
update_repo_as_user() {
  local repo_path="$1"
  local current_user

  # Determine current user (handle sudo)
  if [[ -n "$SUDO_USER" ]]; then
    current_user="$SUDO_USER"
  else
    current_user="$(whoami)"
  fi

  # Validate input
  if [[ ! -d "${repo_path}/.git" ]]; then
    echo "✗ ERROR: Not a git repository: ${repo_path}"
    return 1
  fi

  # Check current ownership
  local owner=$(stat -f "%Su" "${repo_path}" 2>/dev/null || stat -c "%U" "${repo_path}" 2>/dev/null)

  # If owned by root, temporarily fix ownership for the pull
  if [[ "$owner" == "root" ]]; then
    echo "  Repository owned by root, fixing ownership..."
    sudo chown -R "${current_user}" "${repo_path}" || {
      echo "✗ ERROR: Cannot fix repository ownership"
      return 1
    }
  fi

  # Perform pull as user (has SSH access)
  echo "  Pulling latest changes..."
  if (cd "${repo_path}" && git pull 2>&1 | tee /dev/tty | grep -q "Already up to date\|Updating"); then
    return 0
  else
    echo ""
    echo "✗ ERROR: Failed to pull updates"
    return 1
  fi
}

switch_to_zsh() {
  local current_shell zsh_path

  if [[ "$DF_PLATFORM" == "macOS" ]]; then
    current_shell=$(dscl . -read /Users/"$USER" UserShell | awk '{print $2}')
  else
    if command -v getent >/dev/null 2>&1; then
      current_shell=$(getent passwd "$USER" | cut -d: -f7)
    else
      current_shell=$(grep "^$USER:" /etc/passwd | cut -d: -f7)
    fi
  fi

  zsh_path=$(command -v zsh)

  if [[ "$current_shell" == "$zsh_path" ]]; then
    echo "zsh is already the default shell. Switching for current session..."
    exec "$zsh_path"
    return 0
  fi

  if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    echo "Changing default shell to zsh..."
    chsh -s "$zsh_path"
  fi

  echo "Switching to zsh for current session..."
  exec "$zsh_path"
}

install_homebrew() {
  if [[ "$DF_PLATFORM" == "macOS" ]] && ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> "${ORIGINAL_USER_HOME}/.zshrc"
    eval "$(/opt/homebrew/bin/brew shellenv)"
    echo "Homebrew installation complete."
  else
    echo "Homebrew already installed or not on macOS."
  fi
}

install_tui_dependencies() {
  echo "Installing TUI dependencies (gum, fzf)..."
  
  if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    # Install fzf
    if ! command -v fzf &>/dev/null; then
      echo "  Installing fzf..."
      sudo apt install -y fzf
    else
      echo "  ✓ fzf already installed"
    fi
    
    # Install gum
    if ! command -v gum &>/dev/null; then
      echo "  Installing gum..."
      # gum requires adding charm repo on Ubuntu
      sudo mkdir -p /etc/apt/keyrings
      curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
      echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list
      sudo apt update && sudo apt install -y gum
    else
      echo "  ✓ gum already installed"
    fi
  elif [[ "$DF_PLATFORM" == "macOS" ]]; then
    # macOS installs via Homebrew
    if ! command -v fzf &>/dev/null; then
      echo "  Installing fzf..."
      brew install fzf
    else
      echo "  ✓ fzf already installed"
    fi
    
    if ! command -v gum &>/dev/null; then
      echo "  Installing gum..."
      brew install gum
    else
      echo "  ✓ gum already installed"
    fi
  fi
  
  echo "TUI dependencies ready."
}

install_zsh() {
  if ! command -v zsh &>/dev/null; then
    echo "Installing ZSH..."
    if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
      sudo apt update -q && sudo apt install -y zsh
    fi
  fi
  touch "${ORIGINAL_USER_HOME}/.zshrc"
  echo "ZSH ready."
}

# Create kgroup and dotFiles registry infrastructure
setup_kgroup_infrastructure() {
  local GROUP_NAME="kgroup"
  local REGISTRY_DIR="/opt/.config/dotFiles"
  local CURRENT_USER

  # Determine current user (handle sudo)
  if [[ -n "$SUDO_USER" ]]; then
    CURRENT_USER="$SUDO_USER"
  else
    CURRENT_USER="$(whoami)"
  fi

  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         Setting Up kgroup Infrastructure         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""

  # Create kgroup based on platform
  if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    # Ubuntu: use groupadd
    if ! getent group "$GROUP_NAME" >/dev/null 2>&1; then
      echo "Creating group: $GROUP_NAME"
      sudo groupadd "$GROUP_NAME"
      echo "✓ Group created"
    else
      echo "✓ Group already exists: $GROUP_NAME"
    fi

    # Add current user to kgroup
    if ! groups "$CURRENT_USER" | grep -qw "$GROUP_NAME"; then
      echo "Adding $CURRENT_USER to $GROUP_NAME"
      sudo usermod -aG "$GROUP_NAME" "$CURRENT_USER"
      echo "✓ User added to group"
    else
      echo "✓ $CURRENT_USER already in $GROUP_NAME"
    fi

    # Add root to kgroup
    sudo usermod -aG "$GROUP_NAME" root 2>/dev/null || true

  elif [[ "$DF_PLATFORM" == "macOS" ]]; then
    # macOS: use dseditgroup
    if ! dscl . -read /Groups/"$GROUP_NAME" &>/dev/null; then
      echo "Creating group: $GROUP_NAME"
      sudo dseditgroup -o create "$GROUP_NAME"
      echo "✓ Group created"
    else
      echo "✓ Group already exists: $GROUP_NAME"
    fi

    # Add current user to kgroup
    if ! dscl . -read /Groups/"$GROUP_NAME" GroupMembership 2>/dev/null | grep -qw "$CURRENT_USER"; then
      echo "Adding $CURRENT_USER to $GROUP_NAME"
      sudo dseditgroup -o edit -a "$CURRENT_USER" -t user "$GROUP_NAME"
      echo "✓ User added to group"
    else
      echo "✓ $CURRENT_USER already in $GROUP_NAME"
    fi

    # Add root to kgroup
    sudo dseditgroup -o edit -a root -t user "$GROUP_NAME" 2>/dev/null || true
  fi

  # Create registry directory infrastructure
  echo ""
  echo "Creating dotFiles registry infrastructure..."

  if [[ ! -d "$REGISTRY_DIR" ]]; then
    sudo mkdir -p "$REGISTRY_DIR"
    echo "✓ Created: $REGISTRY_DIR"
  else
    echo "✓ Registry directory already exists"
  fi

  # Set ownership and permissions
  sudo chown root:"$GROUP_NAME" "$REGISTRY_DIR"
  sudo chmod 2775 "$REGISTRY_DIR"  # setgid bit + group writable

  echo "✓ Permissions configured (root:$GROUP_NAME, 2775)"
  echo ""
  echo "kgroup infrastructure ready!"
  echo ""
}

# Optional: Install 1Password CLI for secret management
setup_1password_optional() {
  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         1Password Setup (Optional)         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""
  echo "1Password provides secure secret management including:"
  echo "  • API keys (Cloudflare, SMTP, etc.)"
  echo "  • SSH keys with biometric unlock"
  echo "  • Git-crypt keys"
  echo ""

  # Check if 1Password app is installed
  local app_installed=false
  if [[ "$DF_PLATFORM" == "macOS" ]]; then
    if [[ -d "/Applications/1Password.app" ]]; then
      app_installed=true
      echo "✓ 1Password app detected"
    fi
  elif [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    if command -v 1password &>/dev/null; then
      app_installed=true
      echo "✓ 1Password app detected"
    fi
  fi

  if [[ "$app_installed" == "false" ]]; then
    echo "ℹ  1Password app NOT detected"
    echo ""
    echo "The CLI works standalone - the desktop app is optional."
    echo ""
    echo "Optional desktop app features (macOS only):"
    echo "  • SSH agent with biometric unlock (Touch ID/Face ID)"
    echo "  • GUI for managing passwords"
    echo ""
    echo "To install later (optional):"
    echo "  • macOS: https://1password.com/downloads/mac/"
    echo "  • Ubuntu: https://1password.com/downloads/linux/"
    echo ""
  fi

  read -p "Install 1Password CLI? (Y/n): " install_op

  if [[ "$install_op" =~ ^[nN]$ ]]; then
    echo "⊘ Skipping 1Password CLI - will use manual entry for secrets"
    return 0
  fi

  # Install op CLI if needed
  if ! command -v op &>/dev/null; then
    echo ""
    echo "Installing 1Password CLI..."

    if [[ "$DF_PLATFORM" == "macOS" ]]; then
      if command -v brew &>/dev/null; then
        if brew install --cask 1password-cli; then
          echo "✅ 1Password CLI installed"
        else
          echo "⚠ Failed to install 1Password CLI"
          return 1
        fi
      else
        echo "⚠ Homebrew required for 1Password CLI installation"
        return 1
      fi
    elif [[ "$DF_PLATFORM" == "ubuntu" ]]; then
      # Download and add 1Password GPG key
      if curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
        sudo gpg --dearmor --output /usr/share/keyrings/1password-archive-keyring.gpg; then

        # Add 1Password repository
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/$(dpkg --print-architecture) stable main" | \
          sudo tee /etc/apt/sources.list.d/1password.list > /dev/null

        # Add debsig-verify policy for package verification
        echo "Setting up package verification..."
        sudo mkdir -p /etc/debsig/policies/AC2D62742012EA22/
        curl -sS https://downloads.1password.com/linux/debian/debsig/1password.pol | \
          sudo tee /etc/debsig/policies/AC2D62742012EA22/1password.pol > /dev/null
        sudo mkdir -p /usr/share/debsig/keyrings/AC2D62742012EA22
        curl -sS https://downloads.1password.com/linux/keys/1password.asc | \
          sudo gpg --dearmor --output /usr/share/debsig/keyrings/AC2D62742012EA22/debsig.gpg

        # Update and install
        if sudo apt update -q && sudo apt install -y 1password-cli; then
          echo "✅ 1Password CLI installed"
        else
          echo "⚠ Failed to install 1Password CLI"
          return 1
        fi
      else
        echo "⚠ Failed to add 1Password GPG key"
        return 1
      fi
    fi
  else
    echo "✓ 1Password CLI already installed"
  fi

  # Try to authenticate - platform-specific flows
  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         1Password Authentication         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""

  # Check if already signed in
  if op account list &>/dev/null; then
    echo "✓ Already signed in to 1Password"
    echo ""
    op account list
    echo ""
    echo "✅ 1Password authentication successful"
    echo ""
    if [[ "$DF_PLATFORM" == "macOS" ]]; then
      echo "To enable SSH agent integration:"
      echo "  1. Open 1Password"
      echo "  2. Settings → Developer → Enable 'Use the SSH agent'"
      echo ""
    fi
    return 0
  fi

  # Unified CLI-only authentication for both platforms
  # Works over SSH and remote terminals, no GUI required
  echo "Using CLI-only authentication (works locally and over SSH)."
  echo ""
  echo "You'll need:"
  echo "  • Sign-in address (e.g., my.1password.com)"
  echo "  • Email address"
  echo "  • Secret Key"
  echo "  • Master Password"
  echo ""

  # Note about optional desktop app features
  if [[ "$app_installed" == "true" && "$DF_PLATFORM" == "macOS" ]]; then
    echo "Note: Desktop app detected - you can optionally enable:"
    echo "  • SSH agent integration (Settings → Developer → Use SSH agent)"
    echo "  • Biometric unlock for GUI features"
    echo ""
  fi

  read -p "Add 1Password account now? (Y/n): " add_account

  if [[ "$add_account" =~ ^[nN]$ ]]; then
    echo ""
    echo "⊘ Skipping 1Password authentication"
    echo "You can set it up later with: op account add"
    echo ""
    return 1
  fi

  echo ""
  echo "Adding 1Password account..."
  echo ""

  if op account add; then
    echo ""
    echo "✅ 1Password CLI authentication successful"
    echo ""
    echo "Session Management:"
    echo "  • CLI sessions expire after inactivity"
    echo "  • To re-authenticate when session expires:"
    echo "    eval \$(op signin)"
    echo ""
    echo "  • Check if authenticated:"
    echo "    op account list"
    echo ""
    echo "  • For automation (CI/CD, cron jobs):"
    echo "    Use service account tokens: https://developer.1password.com/docs/service-accounts"
    echo ""
    return 0
  else
    echo ""
    echo "⚠ 1Password authentication failed"
    echo "You can set it up later with: op account add"
    echo ""
    return 1
  fi
}

# Re-authenticate to 1Password if session has expired
reauthenticate_1password() {
  # Check if 1Password CLI is installed
  if ! command -v op &>/dev/null; then
    echo "⚠ 1Password CLI not installed"
    return 1
  fi

  # Check if already authenticated
  if op account list &>/dev/null 2>&1; then
    echo "✓ Already authenticated to 1Password"
    return 0
  fi

  # Need to re-authenticate using CLI
  echo "1Password session has expired. Re-authenticating..."
  echo ""
  echo "Signing in with CLI (enter your Master Password)..."
  echo ""

  # Unified CLI signin for both platforms
  if eval $(op signin); then
    echo ""
    echo "✅ Re-authentication successful"
    return 0
  else
    echo ""
    echo "⚠ Re-authentication failed"
    echo "If you need to add the account again: op account add"
    return 1
  fi
}

verify_git_access() {
  # Detect URL type: SSH (git@... or ssh://git@...) or HTTPS (https://...)
  if [[ "$SELECTED_REPO" =~ ^(git@|ssh://) ]]; then
    # SSH format - verify SSH access
    local host

    # Handle both ssh://git@host/path and git@host:path formats
    if [[ "$SELECTED_REPO" =~ ^ssh:// ]]; then
      # Extract host from ssh://git@host/path format
      host=$(echo "$SELECTED_REPO" | sed -n 's#^ssh://git@\([^/]*\)/.*#\1#p')
    else
      # Extract host from git@host:path format
      host=$(echo "$SELECTED_REPO" | sed -n 's#^git@\([^:]*\):.*#\1#p')
    fi

    if [[ -z "$host" ]]; then
      echo "Could not parse SSH host from repository: $SELECTED_REPO"
      return 1
    fi

    echo "Verifying SSH access to ${host}..."

    # Add host key to known_hosts if not already present (silently)
    if ! ssh-keygen -F "$host" >/dev/null 2>&1; then
      echo "Adding ${host} to known_hosts..."
      ssh-keyscan -H "$host" >> ~/.ssh/known_hosts 2>/dev/null
    fi

    if ssh -o BatchMode=yes -o StrictHostKeyChecking=no -T "git@${host}" 2>&1 | grep -qi "successfully authenticated"; then
      echo "✅ SSH access to ${host} verified."
    else
      echo "⚠️  SSH access to ${host} failed."
      echo "SSH keys may not be configured yet. You can:"
      echo "  1. Continue with HTTPS (will be converted to SSH later)"
      echo "  2. Set up SSH keys first and retry"
      echo ""
      read -p "Continue anyway? (Y/n): " continue_choice
      if [[ "$continue_choice" =~ ^[nN]$ ]]; then
        exit 1
      fi
    fi
  elif [[ "$SELECTED_REPO" =~ ^https?:// ]]; then
    # HTTPS format - no SSH verification needed
    echo "Using HTTPS clone (SSH keys not required yet)"
    echo "✓ Repository URL accepted: $SELECTED_REPO"
  else
    echo "❌ Unsupported repository URL format: $SELECTED_REPO"
    echo "Please use either:"
    echo "  • HTTPS: https://github.com/username/dotFiles.git"
    echo "  • SSH:   ssh://git@github.com/username/dotFiles.git"
    echo "  • SSH:   git@github.com:username/dotFiles.git (traditional format)"
    exit 1
  fi
}

# Install or update Trove utilities library
install_trove() {
  local TROVE_HOME="/opt/trove"
  local TROVE_REPO="${DF_TROVE_REPO:-ssh://git@git.thesecretlab.io/marana/trove.git}"
  local TROVE_DEV_PATH="${HOME}/Sourcecode/thesecretlab/trove"
  local CURRENT_USER

  # Determine current user (handle sudo)
  if [[ -n "$SUDO_USER" ]]; then
    CURRENT_USER="$SUDO_USER"
  else
    CURRENT_USER="$(whoami)"
  fi

  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         Setting Up Trove Utilities Library         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""

  # Check if already installed (update if exists)
  if [[ -d "${TROVE_HOME}/.git" ]]; then
    echo "Trove already installed. Checking for updates..."

    # Store current commit for comparison
    local current_commit
    current_commit=$(cd "${TROVE_HOME}" && git rev-parse HEAD 2>/dev/null)

    # Attempt to pull updates with proper error handling
    if update_repo_as_user "${TROVE_HOME}"; then
      local new_commit
      new_commit=$(cd "${TROVE_HOME}" && git rev-parse HEAD 2>/dev/null)

      if [[ "$current_commit" == "$new_commit" ]]; then
        echo "✓ Trove already up to date"
      else
        echo "✓ Trove updated successfully (${current_commit:0:8} → ${new_commit:0:8})"
      fi
    else
      echo ""
      echo "✗ ERROR: Failed to update Trove"
      echo "  Current installation may be corrupted or repository unreachable"
      echo ""
      echo "Options to resolve:"
      echo "  1. Check SSH access: ssh -T git@git.thesecretlab.io"
      echo "  2. Remove and reinstall: sudo rm -rf ${TROVE_HOME} && ./bootstrap install"
      echo "  3. Use development mode: link from ~/Sourcecode/thesecretlab/trove"
      echo ""
      return 1
    fi

    # Verify installation is still valid after update
    if [[ ! -f "${TROVE_HOME}/lib/trove_logging.zsh" ]]; then
      echo ""
      echo "✗ ERROR: Trove installation corrupted after update"
      echo "  Missing: ${TROVE_HOME}/lib/trove_logging.zsh"
      echo ""
      echo "Run: sudo rm -rf ${TROVE_HOME} && ./bootstrap install"
      echo ""
      return 1
    fi

    echo "✓ Trove installation verified"
    echo ""
    return 0
  fi

  echo "Installing Trove utilities library..."
  echo ""

  # Ensure parent directory exists
  if [[ ! -d "/opt" ]]; then
    echo "Creating /opt directory..."
    sudo mkdir -p /opt || {
      echo "✗ ERROR: Cannot create /opt directory"
      return 1
    }
  fi

  # Development mode: symlink if local dev copy exists
  if [[ -d "${TROVE_DEV_PATH}/.git" ]]; then
    echo "→ Development mode detected"
    echo "  Symlinking from: ${TROVE_DEV_PATH}"
    echo ""

    # Verify dev copy has required files
    if [[ ! -f "${TROVE_DEV_PATH}/lib/trove_logging.zsh" ]]; then
      echo "✗ ERROR: Development copy appears incomplete"
      echo "  Missing: ${TROVE_DEV_PATH}/lib/trove_logging.zsh"
      echo "  Please ensure dev repository is properly cloned"
      return 1
    fi

    if sudo ln -sf "${TROVE_DEV_PATH}" "${TROVE_HOME}"; then
      echo "✓ Trove symlinked from development copy"
    else
      echo "✗ ERROR: Failed to create symlink"
      echo "  Please check permissions on /opt"
      return 1
    fi
  else
    # Production mode: clone from repository
    echo "→ Cloning Trove from repository"
    echo "  Repository: ${TROVE_REPO}"
    echo ""

    if clone_repo_as_user_to_opt "${TROVE_REPO}" "${TROVE_HOME}"; then
      echo "✓ Trove cloned successfully"
    else
      echo ""
      echo "✗ ERROR: Failed to clone Trove repository"
      echo ""
      echo "This likely means SSH access is not configured yet."
      echo ""
      echo "Options to resolve:"
      echo "  1. Set up SSH keys and retry"
      echo "     - Add SSH key: ssh-keygen -t ed25519"
      echo "     - Add to git server: cat ~/.ssh/id_ed25519.pub"
      echo "     - Test: ssh -T git@git.thesecretlab.io"
      echo "  2. Use HTTPS temporarily:"
      echo "     export DF_TROVE_REPO='https://git.thesecretlab.io/marana/trove.git'"
      echo "  3. Install manually after bootstrap:"
      echo "     git clone <repo-url> ~/.temp_trove && sudo mv ~/.temp_trove ${TROVE_HOME}"
      echo ""
      return 1
    fi
  fi

  # Set ownership to current user and kgroup
  echo ""
  echo "Setting ownership and permissions..."

  if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    # Linux: check if kgroup exists
    if getent group kgroup &>/dev/null; then
      sudo chown -R "${CURRENT_USER}:kgroup" "${TROVE_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:kgroup"
    else
      sudo chown -R "${CURRENT_USER}:${CURRENT_USER}" "${TROVE_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:${CURRENT_USER}"
      echo "⚠ Warning: kgroup not found, using user ownership"
    fi
  elif [[ "$DF_PLATFORM" == "macOS" ]]; then
    # macOS: check if kgroup exists
    if dscl . -read /Groups/kgroup &>/dev/null 2>&1; then
      sudo chown -R "${CURRENT_USER}:kgroup" "${TROVE_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:kgroup"
    else
      sudo chown -R "${CURRENT_USER}:staff" "${TROVE_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:staff"
      echo "⚠ Warning: kgroup not found, using staff ownership"
    fi
  fi

  # Verify installation
  if [[ -f "${TROVE_HOME}/lib/trove_logging.zsh" ]]; then
    echo "✓ Trove installation verified"
    echo ""
    echo "Trove utilities library ready!"
    echo ""
    return 0
  else
    echo ""
    echo "✗ ERROR: Trove installation incomplete"
    echo "  Missing: ${TROVE_HOME}/lib/trove_logging.zsh"
    echo ""
    echo "This indicates the repository may not have the expected structure."
    echo "Please verify the repository contents and try again."
    echo ""
    return 1
  fi
}

# Install or update Beskar security utilities library
install_beskar() {
  local BESKAR_HOME="/opt/beskar"
  local BESKAR_REPO="${DF_BESKAR_REPO:-ssh://git@git.thesecretlab.io/marana/beskar.git}"
  local BESKAR_DEV_PATH="${HOME}/Sourcecode/thesecretlab/beskar"
  local CURRENT_USER

  # Determine current user (handle sudo)
  if [[ -n "$SUDO_USER" ]]; then
    CURRENT_USER="$SUDO_USER"
  else
    CURRENT_USER="$(whoami)"
  fi

  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo "         Setting Up Beskar Security Library         "
  echo "════════════════════════════════════════════════════════════════"
  echo ""

  # Check if already installed (update if exists)
  if [[ -d "${BESKAR_HOME}/.git" ]]; then
    echo "Beskar already installed. Checking for updates..."

    # Store current commit for comparison
    local current_commit
    current_commit=$(cd "${BESKAR_HOME}" && git rev-parse HEAD 2>/dev/null)

    # Attempt to pull updates with proper error handling
    if update_repo_as_user "${BESKAR_HOME}"; then
      local new_commit
      new_commit=$(cd "${BESKAR_HOME}" && git rev-parse HEAD 2>/dev/null)

      if [[ "$current_commit" == "$new_commit" ]]; then
        echo "✓ Beskar already up to date"
      else
        echo "✓ Beskar updated successfully (${current_commit:0:8} → ${new_commit:0:8})"
      fi
    else
      echo ""
      echo "✗ ERROR: Failed to update Beskar"
      echo "  Current installation may be corrupted or repository unreachable"
      echo ""
      echo "Options to resolve:"
      echo "  1. Check SSH access: ssh -T git@git.thesecretlab.io"
      echo "  2. Remove and reinstall: sudo rm -rf ${BESKAR_HOME} && ./bootstrap install"
      echo "  3. Use development mode: link from ~/Sourcecode/thesecretlab/beskar"
      echo ""
      return 1
    fi

    # Verify installation is still valid after update
    if [[ ! -f "${BESKAR_HOME}/lib/beskar_core.zsh" ]]; then
      echo ""
      echo "✗ ERROR: Beskar installation corrupted after update"
      echo "  Missing: ${BESKAR_HOME}/lib/beskar_core.zsh"
      echo ""
      echo "Run: sudo rm -rf ${BESKAR_HOME} && ./bootstrap install"
      echo ""
      return 1
    fi

    echo "✓ Beskar installation verified"
    echo ""
    return 0
  fi

  echo "Installing Beskar security library..."
  echo ""

  # Ensure parent directory exists
  if [[ ! -d "/opt" ]]; then
    echo "Creating /opt directory..."
    sudo mkdir -p /opt || {
      echo "✗ ERROR: Cannot create /opt directory"
      echo "  Check sudo permissions"
      return 1
    }
  fi

  # Development mode: symlink if local dev copy exists
  if [[ -d "${BESKAR_DEV_PATH}/.git" ]]; then
    echo "→ Development mode detected"
    echo "  Symlinking from: ${BESKAR_DEV_PATH}"
    echo ""

    # Verify dev copy has required files
    if [[ ! -f "${BESKAR_DEV_PATH}/lib/beskar_core.zsh" ]]; then
      echo "✗ ERROR: Development copy appears incomplete"
      echo "  Missing: ${BESKAR_DEV_PATH}/lib/beskar_core.zsh"
      echo "  Please ensure dev repository is properly cloned"
      return 1
    fi

    if sudo ln -sf "${BESKAR_DEV_PATH}" "${BESKAR_HOME}"; then
      echo "✓ Beskar symlinked from development copy"
    else
      echo "✗ ERROR: Failed to create symlink"
      echo "  Please check permissions on /opt"
      return 1
    fi
  else
    # Production mode: clone from repository
    echo "→ Cloning Beskar from repository"
    echo "  Repository: ${BESKAR_REPO}"
    echo ""

    if clone_repo_as_user_to_opt "${BESKAR_REPO}" "${BESKAR_HOME}"; then
      echo "✓ Beskar cloned successfully"
    else
      echo ""
      echo "✗ ERROR: Failed to clone Beskar repository"
      echo ""
      echo "This likely means SSH access is not configured yet."
      echo ""
      echo "Options to resolve:"
      echo "  1. Set up SSH keys and retry"
      echo "     - Add SSH key: ssh-keygen -t ed25519"
      echo "     - Add to git server: cat ~/.ssh/id_ed25519.pub"
      echo "     - Test: ssh -T git@git.thesecretlab.io"
      echo "  2. Use HTTPS temporarily:"
      echo "     export DF_BESKAR_REPO='https://git.thesecretlab.io/marana/beskar.git'"
      echo "  3. Install manually after bootstrap:"
      echo "     git clone <repo-url> ~/.temp_beskar && sudo mv ~/.temp_beskar ${BESKAR_HOME}"
      echo ""
      return 1
    fi
  fi

  # Set ownership to current user and kgroup
  echo ""
  echo "Setting ownership and permissions..."

  if [[ "$DF_PLATFORM" == "ubuntu" ]]; then
    # Linux: check if kgroup exists
    if getent group kgroup &>/dev/null; then
      sudo chown -R "${CURRENT_USER}:kgroup" "${BESKAR_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:kgroup"
    else
      sudo chown -R "${CURRENT_USER}:${CURRENT_USER}" "${BESKAR_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:${CURRENT_USER}"
      echo "⚠ Warning: kgroup not found, using user ownership"
    fi
  elif [[ "$DF_PLATFORM" == "macOS" ]]; then
    # macOS: check if kgroup exists
    if dscl . -read /Groups/kgroup &>/dev/null 2>&1; then
      sudo chown -R "${CURRENT_USER}:kgroup" "${BESKAR_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:kgroup"
    else
      sudo chown -R "${CURRENT_USER}:staff" "${BESKAR_HOME}"
      echo "✓ Ownership set to ${CURRENT_USER}:staff"
      echo "⚠ Warning: kgroup not found, using staff ownership"
    fi
  fi

  # Verify installation
  if [[ -f "${BESKAR_HOME}/lib/beskar_core.zsh" ]]; then
    echo "✓ Beskar installation verified"
    echo ""
    echo "Beskar security library ready!"
    echo ""
    return 0
  else
    echo ""
    echo "✗ ERROR: Beskar installation incomplete"
    echo "  Missing: ${BESKAR_HOME}/lib/beskar_core.zsh"
    echo ""
    echo "This indicates the repository may not have the expected structure."
    echo "Please verify the repository contents and try again."
    echo ""
    return 1
  fi
}

ensure_bootstrap_ssh_connectivity() {
  echo "Ensuring Bootstrap repository uses SSH connectivity..."

  # Get current remote URL
  local current_url
  current_url=$(git remote get-url origin 2>/dev/null)

  if [[ -z "$current_url" ]]; then
    echo "[✗] No origin remote found in Bootstrap repository"
    return 1
  fi

  echo "[i] Current Bootstrap remote: $current_url"

  # Check if already using SSH (both ssh:// and git@ formats)
  if [[ "$current_url" =~ ^(git@|ssh://) ]]; then
    echo "[✓] Bootstrap already using SSH: $current_url"
    return 0
  fi

  # Convert HTTP/HTTPS to SSH (generic pattern for any domain)
  if [[ "$current_url" =~ ^https?:// ]]; then
    local ssh_url

    # Generic HTTP/HTTPS to SSH conversion: http(s)://domain.com/user/repo → ssh://git@domain.com/user/repo
    ssh_url=$(echo "$current_url" | sed -E 's|^https?://|ssh://git@|')

    echo "[→] Converting Bootstrap remote to SSH: $ssh_url"
    if git remote set-url origin "$ssh_url"; then
      echo "[✓] Successfully updated Bootstrap remote to SSH"
      
      # Test SSH connectivity
      if git fetch --quiet origin 2>/dev/null; then
        echo "[✓] SSH connectivity test successful"
        return 0
      else
        echo "[✗] SSH connectivity test failed - reverting"
        git remote set-url origin "$current_url"
        return 1
      fi
    else
      echo "[✗] Failed to update remote URL"
      return 1
    fi
  else
    echo "[✗] Remote URL is not HTTPS: $current_url"
    return 1
  fi
}

complete_bootstrap_and_offer_dotfiles_install() {
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║              Bootstrap Setup Complete!                       ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Bootstrap components installed:"
  if [[ "$DF_PLATFORM" == "macOS" ]]; then
    echo "  ✓ Homebrew (if needed)"
  fi
  echo "  ✓ ZSH"
  if command -v op &>/dev/null; then
    echo "  ✓ 1Password CLI"
  fi
  echo ""
  echo "dotFiles is already present at: ${TARGET}"
  echo ""
  echo "════════════════════════════════════════════════════════════════"
  echo ""
  echo "Next step: Run dotFiles installation"
  echo ""
  echo "Options:"
  echo "  1. Run dotFiles installation now"
  echo "  2. Exit (install later manually)"
  echo ""
  read -p "Choose option (1/2): " run_dotfiles

  case "$run_dotfiles" in
    1)
      # Check if dotFiles directory exists and has install script
      if [[ ! -x "${TARGET}/install/install.zsh" ]]; then
        echo ""
        echo "⚠ dotFiles appears incomplete (missing install/install.zsh)"
        echo "Please run: cd ${TARGET} && git pull"
        return 1
      fi

      echo ""
      echo "════════════════════════════════════════════════════════════════"
      echo "         Starting dotFiles Installation         "
      echo "════════════════════════════════════════════════════════════════"
      echo ""

      cd "${TARGET}" || return 1

      # Run the install script directly (not through df wrapper which requires env)
      if [[ -x "./install/install.zsh" ]]; then
        # Explicitly pass current environment to ensure PATH is preserved
        env PATH="$PATH" ./install/install.zsh
      else
        echo "⚠ Install script not found at ${TARGET}/install/install.zsh"
        return 1
      fi

      switch_to_zsh
      ;;
    2|*)
      echo ""
      echo "Bootstrap complete!"
      echo ""
      echo "To install dotFiles later, run:"
      echo "  cd ${TARGET} && ./install/install.zsh"
      echo ""
      return 0
      ;;
  esac
}

install_dotfiles() {
  echo "Setting up .dotFiles..."

  # Check if dotFiles already exists
  if [[ -d "${TARGET}" ]]; then
    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "         dotFiles Already Installed         "
    echo "════════════════════════════════════════════════════════════════"
    echo ""
    echo "dotFiles is already installed at: ${TARGET}"
    echo ""
    echo "Options:"
    echo "  1. Skip dotFiles installation and continue with bootstrap setup"
    echo "  2. Refresh dotFiles (delete and re-download)"
    echo "  3. Exit"
    echo ""
    read -p "Choose option (1/2/3): " dotfiles_choice

    case "$dotfiles_choice" in
      1)
        echo ""
        echo "Skipping dotFiles clone..."
        echo "Continuing with bootstrap setup..."
        echo ""
        install_homebrew
        install_zsh
        install_tui_dependencies
        setup_1password_optional
        setup_kgroup_infrastructure

        # Ensure trove and beskar are installed even if dotFiles exists
        install_trove || {
          echo "⚠ Warning: Trove installation failed (non-critical for existing dotFiles)"
        }
        install_beskar || {
          echo "⚠ Warning: Beskar installation failed (non-critical for existing dotFiles)"
        }

        # Bootstrap complete - offer to run dotFiles install
        complete_bootstrap_and_offer_dotfiles_install
        return 0
        ;;
      2)
        echo ""
        echo "Refreshing dotFiles (this will delete and re-download)..."
        echo ""
        read -p "Are you sure? This will delete ${TARGET} (y/N): " confirm_delete
        if [[ ! "$confirm_delete" =~ ^[yY]$ ]]; then
          echo "Refresh cancelled. Exiting."
          exit 0
        fi
        echo "Deleting ${TARGET}..."
        rm -rf "${TARGET}"
        echo "✓ Deleted"
        echo ""
        # Fall through to normal installation
        ;;
      3)
        echo "Exiting."
        exit 0
        ;;
      *)
        echo "Invalid choice. Exiting."
        exit 1
        ;;
    esac
  fi

  # Configure repository first
  configure_repository || return 1

  install_homebrew
  install_zsh
  install_tui_dependencies
  setup_1password_optional
  setup_kgroup_infrastructure
  install_trove || {
    echo ""
    echo "✗ FATAL: Trove installation failed"
    echo "  Cannot proceed without Trove utilities"
    echo ""
    exit 1
  }
  install_beskar || {
    echo ""
    echo "✗ FATAL: Beskar installation failed"
    echo "  Cannot proceed without Beskar security library"
    echo ""
    exit 1
  }
  verify_git_access

  # Optional: Ensure bootstrap repo uses SSH (only if user wants auto-conversion)
  # Uncomment the next line if you want to force SSH for bootstrap repo
  # ensure_bootstrap_ssh_connectivity

  local branch_or_tag="${BRANCH:-main}"

  echo "Cloning from ${SELECTED_REPO}..."
  if git clone --depth 1 --branch "${branch_or_tag}" "${SELECTED_REPO}" "${TARGET}"; then
    cd "${TARGET}" || exit 1
    echo "✓ dotFiles repository cloned successfully."
    echo ""

    # Set kgroup ownership immediately after clone
    echo "Setting group ownership to kgroup..."
    if sudo chgrp -R kgroup "${TARGET}"; then
      # Set group read+execute permissions
      sudo find "${TARGET}" -type d -exec chmod g+rx {} \; 2>/dev/null
      sudo find "${TARGET}" -type f \( -name "*.zsh" -o -name "*.sh" \) -exec chmod g+rx {} \; 2>/dev/null
      sudo find "${TARGET}" -type f ! \( -name "*.zsh" -o -name "*.sh" \) -exec chmod g+r {} \; 2>/dev/null
      echo "✓ Group permissions configured (kgroup)"
    else
      echo "⚠ Could not set group ownership (non-critical, can run 'df heal' later)"
    fi
    echo ""

    # Optional: Convert HTTPS to SSH (only if user wants auto-conversion)
    # Uncomment the lines below if you want to automatically convert HTTPS to SSH
    # if [[ "$SELECTED_REPO" =~ ^https?:// ]]; then
    #   echo "Attempting to convert remote from HTTPS to SSH..."
    #   convert_git_remote_to_ssh "${TARGET}" "${SELECTED_REPO}"
    # fi

    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║              Bootstrap Setup Complete!                       ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "Bootstrap components installed:"
    if [[ "$DF_PLATFORM" == "macOS" ]]; then
      echo "  ✓ Homebrew"
    fi
    echo "  ✓ ZSH"
    if command -v op &>/dev/null; then
      echo "  ✓ 1Password CLI"
    fi
    echo "  ✓ kgroup (shared utilities group)"
    echo "  ✓ Trove utilities library"
    echo "  ✓ Beskar security library"
    echo "  ✓ dotFiles registry infrastructure"
    echo "  ✓ dotFiles repository cloned (kgroup permissions set)"
    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "         Starting dotFiles Installation         "
    echo "════════════════════════════════════════════════════════════════"
    echo ""

    # Run the dotFiles install script directly (not through df wrapper which requires env)
    if [[ -x "./install/install.zsh" ]]; then
      # Explicitly pass current environment to ensure PATH is preserved
      env PATH="$PATH" ./install/install.zsh
    else
      echo "Warning: Install script not found. Manual setup required."
      echo "Please run: cd ${TARGET} && ./install/install.zsh"
    fi

    switch_to_zsh
  else
    echo "Git clone failed. Exiting."
    exit 1
  fi
}

refresh_dotfiles() {
  echo "Refreshing .dotFiles..."
  local branch_or_tag="${1:-main}"

  if [[ "${branch_or_tag}" == "--hard" ]]; then
    branch_or_tag="${2:-main}"
    echo "Hard reset to ${branch_or_tag}..."
    rm -rf "${TARGET}"
    if git clone --depth 1 --branch "${branch_or_tag}" "${SELECTED_REPO}" "${TARGET}"; then
      cd "${TARGET}" || exit 1
    else
      echo "Clone failed. Exiting."
      exit 1
    fi
  else
    cd "${TARGET}" || exit 1
    if git rev-parse --verify "refs/tags/${branch_or_tag}" >/dev/null 2>&1; then
      echo "Checking out tag ${branch_or_tag}..."
      git fetch --tags
      git checkout "tags/${branch_or_tag}" -b "${branch_or_tag}-branch"
    else
      echo "Pulling updates from branch ${branch_or_tag}..."
      git pull origin "${branch_or_tag}" || exit 1
    fi
  fi
}

# Main logic
case ${COMMAND} in
  "" | "-h" | "--help")
    show_help
    ;;
  init)
    echo "Environment file is now managed separately. No action performed."
    ;;
  install)
    if [[ -x "${ORIGINAL_USER_HOME}/.bootstrap/GitHarness.sh" ]]; then
      "${ORIGINAL_USER_HOME}/.bootstrap/GitHarness.sh"
    fi
    install_dotfiles
    ;;
  refresh)
    refresh_dotfiles "$2"
    ;;
  1password-reauth | reauth-1password | op-reauth)
    reauthenticate_1password
    ;;
  *)
    echo "Unknown command: ${COMMAND}" >&2
    show_help
    exit 1
    ;;
esac